{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./src/*"
            ]
        },
        "forceConsistentCasingInFileNames": true,
        "module": "ESNext",
        "moduleResolution": "Node",
        "jsx": "react-jsx",
        "checkJs": true
    },
    "exclude": [
        "node_modules",
        "dist"
    ]
}